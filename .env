STORAGE_DIRECTORY=/mnt/storage
CONFIG_DIRECTORY=/mnt/flash/docker-everything-on-it/config
VERSION=docker
TZ=US/Central
PUID=1000
PGID=100
WEBPROXY_ENABLED=false
OPENVPN_PROVIDER=PIA
OPENVPN_OPTS=--auth-nocache --inactive 3600 --ping 10 --ping-exit 60
OPENVPN_CONFIG=us_texas,us_west,us_east
LOCAL_NETWORK=192.168.20.0/24